# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados (SQLite - padrão)
DB_CLIENT=sqlite3
DB_FILENAME=./database/valora.db

# Para PostgreSQL, descomente e configure:
# DB_CLIENT=pg
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=sua_senha
# DB_NAME=valora_db

# Para MySQL, descomente e configure:
# DB_CLIENT=mysql2
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=sua_senha
# DB_NAME=valora_db

# Segurança
API_KEY=sua_chave_secreta_aqui
